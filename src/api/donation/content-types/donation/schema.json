{
  "kind": "collectionType",
  "collectionName": "donations",
  "info": {
    "singularName": "donation",
    "pluralName": "donations",
    "displayName": "Donation",
    "description": "Donaciones recibidas a través de Bold"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "donorFullName": {
      "type": "string",
      "maxLength": 150,
      "required": false
    },
    "donorPhone": {
      "type": "string",
      "maxLength": 20,
      "required": false
    },
    "donorIdentification": {
      "type": "string",
      "maxLength": 30,
      "required": false
    },
    "donorIdentificationType": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "CC",
        "CE",
        "NIT",
        "PP",
        "TI"
      ]
    },
    "boldPaymentId": {
      "type": "string",
      "maxLength": 50,
      "required": false,
      "unique": false
    },
    "boldNotificationId": {
      "type": "string",
      "maxLength": 100,
      "required": false
    },
    "eventType": {
      "type": "enumeration",
      "required": false,
      "enum": [
        "SALE_APPROVED",
        "SALE_REJECTED",
        "VOID_APPROVED",
        "VOID_REJECTED"
      ]
    },
    "amount": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "currency": {
      "type": "string",
      "default": "COP",
      "maxLength": 3,
      "required": false
    },
    "tip": {
      "type": "decimal",
      "required": false,
      "default": 0
    },
    "boldStatus": {
      "type": "enumeration",
      "required": true,
      "default": "pending",
      "enum": [
        "approved",
        "pending",
        "rejected",
        "voided"
      ]
    },
    "paymentMethod": {
      "type": "string",
      "maxLength": 30,
      "required": false
    },
    "integration": {
      "type": "string",
      "maxLength": 30,
      "required": false
    },
    "payerEmail": {
      "type": "string",
      "required": false
    },
    "cardBrand": {
      "type": "string",
      "maxLength": 30,
      "required": false
    },
    "cardMaskedPan": {
      "type": "string",
      "maxLength": 20,
      "required": false
    },
    "reference": {
      "type": "string",
      "maxLength": 100,
      "required": false
    },
    "rawPayload": {
      "type": "json",
      "required": false
    }
  }
}
